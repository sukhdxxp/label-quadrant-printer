# Vision endpoint used by /api/detect-label to locate the shipping label.
# Any OpenAI-compatible chat-completions endpoint with a vision model works.

# --- Default: Gemini (hosted, cheap, fast) -----------------------------------
# Uses Gemini's OpenAI-compatible endpoint. gemini-2.5-flash-lite is the
# cheapest vision tier (~$0.0002/label) and easily handles label detection.
# Get a key at https://aistudio.google.com/apikey
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_MODEL=gemini-2.5-flash-lite
VISION_API_KEY=

# --- Alternative: local LM Studio (no key, fully offline) --------------------
# Load a vision-capable model, start its server, then set:
#   VISION_BASE_URL=http://localhost:1234/v1
#   VISION_MODEL=<exact id from LM Studio's panel, e.g. google/gemma-4-26b-a4b>
#   VISION_API_KEY=        # left blank; LM Studio ignores it
# (Reasoning models work — the function allots enough tokens to think first.)
